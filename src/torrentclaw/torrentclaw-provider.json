{
    "id": "torrentclaw",
    "name": "TorrentClaw (anime)",
    "description": "Torrent search engine via TorrentClaw API. Allows filtering by audio/subtitle language and requiring TrueSpec verification.",
    "manifestURI": "https://raw.githubusercontent.com/Jhoorodre/seanime-provider/refs/heads/master/src/torrentclaw/torrentclaw-provider.json",
    "icon": "https://raw.githubusercontent.com/Jhoorodre/seanime-provider/master/src/icon/torrentclaw.png",
    "version": "1.0.1",
    "author": "jhoorodr",
    "type": "anime-torrent-provider",
    "language": "typescript",
    "lang": "multi",
    "payloadURI": "https://raw.githubusercontent.com/Jhoorodre/seanime-provider/master/src/torrentclaw/torrentclaw-provider.ts",
    "isDevelopment": false,
    "userConfig": {
        "requiresConfig": false,
        "version": 3,
        "fields": [
            {
                "name": "apiKey",
                "label": "TorrentClaw API Key (Optional)",
                "type": "text",
                "default": ""
            },
            {
                "name": "audioLang",
                "label": "Audio Language",
                "type": "select",
                "default": "any",
                "options": [
                    { "label": "Any (Default)", "value": "any" },
                    { "label": "Japanese (ja)", "value": "ja" },
                    { "label": "English (en)", "value": "en" },
                    { "label": "Portuguese (pt)", "value": "pt" },
                    { "label": "Spanish (es)", "value": "es" },
                    { "label": "Latin American Spanish (es-419)", "value": "es-419" },
                    { "label": "French (fr)", "value": "fr" },
                    { "label": "German (de)", "value": "de" },
                    { "label": "Italian (it)", "value": "it" },
                    { "label": "Russian (ru)", "value": "ru" },
                    { "label": "Chinese (zh)", "value": "zh" },
                    { "label": "Korean (ko)", "value": "ko" },
                    { "label": "Arabic (ar)", "value": "ar" }
                ]
            },
            {
                "name": "subsLang",
                "label": "Subtitle Language",
                "type": "select",
                "default": "any",
                "options": [
                    { "label": "Any (Default)", "value": "any" },
                    { "label": "English (en)", "value": "en" },
                    { "label": "Portuguese (pt)", "value": "pt" },
                    { "label": "Spanish (es)", "value": "es" },
                    { "label": "Latin American Spanish (es-419)", "value": "es-419" },
                    { "label": "French (fr)", "value": "fr" },
                    { "label": "German (de)", "value": "de" },
                    { "label": "Italian (it)", "value": "it" },
                    { "label": "Russian (ru)", "value": "ru" },
                    { "label": "Chinese (zh)", "value": "zh" },
                    { "label": "Arabic (ar)", "value": "ar" }
                ]
            },
            {
                "name": "verifiedOnly",
                "label": "Only Verified Torrents (TrueSpec)",
                "type": "switch",
                "default": "false"
            }
        ]
    }
}
